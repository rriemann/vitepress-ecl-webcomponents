{
  "type": "module",
  "devDependencies": {
    "vitepress": "^2.0.0-alpha.17",
    "@stencil/vue-output-target": "^0.13.1",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@ecl/preset-ec": "^5.0.0-RC2",
    "@ecl/theme-ec": "^5.0.0-RC2",
    "@ecl/ecl-webcomponents": "0.24.1",
    "@ecl/ecl-webcomponents-vue": "file:packages/ecl-webcomponents/packages/ecl-webcomponents-vue"
  },
  "scripts": {
    "website:dev": "cp -r node_modules/@ecl/ecl-webcomponents/dist/ecl-webcomponents/build website/public && vitepress dev website",
    "website:build": "vitepress build website && cp -r node_modules/@ecl/ecl-webcomponents/dist/ecl-webcomponents/build website/.vitepress/dist",
    "website:preview": "vitepress preview website",
    "preinstall": "mkdir -p packages/ecl-webcomponents; cd packages/ecl-webcomponents; git init; git remote add -f origin https://github.com/rriemann/ecl-webcomponents.git; git pull --depth=1 origin fix-exports; cd packages/ecl-webcomponents-vue; npm run build"
  }
}
